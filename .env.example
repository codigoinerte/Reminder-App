# URL de NUESTRO backend (no de Evolution directamente).
# Emulador Android: usa 10.0.2.2 para apuntar al localhost del PC.
# Dispositivo físico: usa la IP LAN del PC (ej. 192.168.1.50).
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000

# true  -> usa datos mock en memoria (UI sin backend)
# false -> consume el backend real en EXPO_PUBLIC_API_BASE_URL
EXPO_PUBLIC_USE_MOCK=true
